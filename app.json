{
  "expo": {
    "name": "TPV Móvil Express",
    "slug": "mypos",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "mypos",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mypos.tpv",
      "infoPlist": {
        "NSCameraUsageDescription": "TPV necesita la cámara para tomar fotos de productos.",
        "NSPhotoLibraryUsageDescription": "TPV necesita acceso a la galería para seleccionar fotos de productos.",
        "NSPhotoLibraryAddUsageDescription": "TPV guarda comprobantes en la galería cuando lo solicites.",
        "NSFaceIDUsageDescription": "TPV usa Face ID para autenticarte y proteger tus ventas."
      }
    },
    "android": {
      "package": "com.mypos.tpv",
      "adaptiveIcon": {
        "backgroundColor": "#0f172a"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-secure-store",
      "expo-local-authentication",
      "expo-image-picker",
      "expo-print",
      "expo-sharing",
      "expo-document-picker",
      "expo-file-system",
      "expo-image"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
